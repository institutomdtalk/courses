<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>AQUILES — MD Talk</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Raleway:wght@200;300;400;500&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:         #0d1b2e;
    --navy-mid:     #142240;
    --navy-light:   #1e3358;
    --silver:       #b8c4d0;
    --silver-light: #dce4ec;
    --silver-pale:  #eef2f6;
    --white:        #f8f9fb;
    --pure-white:   #ffffff;
    --accent-silver:#c9d6e3;
    --rule:         rgba(184, 196, 208, 0.3);
    --rule-strong:  rgba(184, 196, 208, 0.6);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
    background: #0d1b2e;
  }

  body {
    background: var(--navy);
    color: var(--silver-light);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    -webkit-transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1), -webkit-transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1), transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.hidden {
    opacity: 0;
    -webkit-transform: translateY(32px);
    transform: translateY(32px);
  }
  .reveal-delay-1 { -webkit-transition-delay: 0.1s;  transition-delay: 0.1s; }
  .reveal-delay-2 { -webkit-transition-delay: 0.22s; transition-delay: 0.22s; }
  .reveal-delay-3 { -webkit-transition-delay: 0.36s; transition-delay: 0.36s; }
  .reveal-delay-4 { -webkit-transition-delay: 0.5s;  transition-delay: 0.5s; }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    padding: 28px 60px;
    padding-left: calc(60px + env(safe-area-inset-left));
    padding-right: calc(60px + env(safe-area-inset-right));
    background: linear-gradient(to bottom, rgba(13,27,46,0.95) 0%, rgba(13,27,46,0) 100%);
    -webkit-transition: background 0.4s, padding 0.4s;
    transition: background 0.4s, padding 0.4s;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  nav.scrolled {
    background: rgba(13,27,46,0.97);
    border-bottom: 1px solid var(--rule);
    padding: 18px 60px;
    padding-left: calc(60px + env(safe-area-inset-left));
    padding-right: calc(60px + env(safe-area-inset-right));
  }
  .nav-logo {
    font-family: 'Raleway', sans-serif;
    font-weight: 200;
    font-size: 0.7rem;
    letter-spacing: 0.45em;
    color: var(--silver);
    text-transform: uppercase;
  }
  .nav-logo span { font-weight: 400; color: var(--pure-white); }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a {
    font-family: 'Raleway', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--silver);
    text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--pure-white); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    min-height: calc(var(--vh, 1vh) * 100);
    background-color: var(--navy);
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-align-items: center;
    align-items: center;
    -webkit-justify-content: center;
    justify-content: center;
    text-align: center;
    position: relative;
    padding: 120px 40px 80px;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(184,196,208,0.03) 0%, transparent 50%),
      radial-gradient(ellipse 80% 60% at 50% 80%, rgba(30,51,88,0.6) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 0.65rem;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--silver);
    margin-bottom: 40px;
    opacity: 0;
    -webkit-animation: fadeUp 1s cubic-bezier(0.22,1,0.36,1) 0.3s forwards;
    animation: fadeUp 1s cubic-bezier(0.22,1,0.36,1) 0.3s forwards;
    position: relative; z-index: 2;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(5.5rem, 14vw, 12rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--pure-white);
    margin-bottom: 16px;
    opacity: 0;
    -webkit-animation: fadeUp 1.1s cubic-bezier(0.22,1,0.36,1) 0.5s forwards;
    animation: fadeUp 1.1s cubic-bezier(0.22,1,0.36,1) 0.5s forwards;
    position: relative; z-index: 2;
  }
  .hero-title em { font-style: italic; color: var(--silver-light); }
  .hero-subtitle-row {
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    gap: 24px;
    margin-bottom: 56px;
    opacity: 0;
    -webkit-animation: fadeUp 1s cubic-bezier(0.22,1,0.36,1) 0.75s forwards;
    animation: fadeUp 1s cubic-bezier(0.22,1,0.36,1) 0.75s forwards;
    position: relative; z-index: 2;
  }
  .hero-subtitle-row .rule-line { width: 48px; height: 1px; background: var(--silver); opacity: 0.5; }
  .hero-subtitle {
    font-family: 'Raleway', sans-serif;
    font-weight: 200;
    font-size: 0.72rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--silver);
  }
  .hero-descriptor {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-style: italic;
    color: var(--silver-light);
    max-width: 580px;
    line-height: 1.7;
    opacity: 0;
    -webkit-animation: fadeUp 1s cubic-bezier(0.22,1,0.36,1) 0.95s forwards;
    animation: fadeUp 1s cubic-bezier(0.22,1,0.36,1) 0.95s forwards;
    position: relative; z-index: 2;
  }
  .hero-scroll-indicator {
    position: absolute;
    bottom: 40px; left: 50%;
    -webkit-transform: translateX(-50%);
    transform: translateX(-50%);
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-align-items: center;
    align-items: center;
    gap: 10px;
    opacity: 0;
    -webkit-animation: fadeIn 1s ease 2s forwards;
    animation: fadeIn 1s ease 2s forwards;
    z-index: 2;
  }
  .hero-scroll-indicator span {
    font-family: 'Raleway', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--silver);
    opacity: 0.5;
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--silver), transparent);
    -webkit-animation: scrollPulse 2s ease-in-out infinite;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  /* ── DIVIDERS ── */
  .section-divider { width: 100%; height: 1px; background: var(--rule); }

  /* ── SECTION ── */
  section {
    position: relative;
    padding: 120px 60px;
    max-width: 1200px;
    margin: 0 auto;
    background: var(--navy);
  }

  /* ── SECTION LABEL ── */
  .section-label {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 0.6rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--silver);
    opacity: 0.6;
    margin-bottom: 56px;
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    gap: 20px;
  }
  .section-label::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: var(--silver);
    opacity: 0.5;
  }

  /* ── INTRO / CONCEITO ── */
  .conceito-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    -webkit-align-items: start;
    align-items: start;
  }
  .conceito-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    line-height: 1.15;
    color: var(--pure-white);
    letter-spacing: -0.01em;
  }
  .conceito-heading em { font-style: italic; color: var(--accent-silver); }
  .conceito-body p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--silver-light);
    margin-bottom: 24px;
    font-weight: 300;
  }
  .conceito-body p:last-child { margin-bottom: 0; }

  /* ── PLATO CALLOUT — navy-mid band ── */
  .plato-band {
    background: var(--navy-mid);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 100px 60px;
  }
  .plato-band-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 80px;
    -webkit-align-items: center;
    align-items: center;
  }
  .plato-label-large {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4.5rem;
    font-weight: 300;
    color: rgba(184,196,208,0.12);
    line-height: 1;
    letter-spacing: -0.03em;
    text-align: center;
  }
  .plato-label-sub {
    font-family: 'Raleway', sans-serif;
    font-size: 0.52rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--silver);
    opacity: 0.35;
    text-align: center;
    margin-top: 8px;
  }
  .plato-definition {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    font-style: italic;
    color: var(--silver-light);
    line-height: 1.6;
  }
  .plato-definition strong {
    font-style: normal;
    font-weight: 500;
    color: var(--pure-white);
  }

  /* ── CONSEQUENCES GRID ── */
  .consequences-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rule);
    margin-top: 0;
  }
  .consequence-card {
    background: var(--navy);
    padding: 52px 40px;
    position: relative;
    overflow: hidden;
    -webkit-transition: background 0.4s;
    transition: background 0.4s;
  }
  .consequence-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 2px; height: 0;
    background: var(--silver);
    opacity: 0.4;
    -webkit-transition: height 0.5s cubic-bezier(0.22,1,0.36,1);
    transition: height 0.5s cubic-bezier(0.22,1,0.36,1);
  }
  .consequence-card:hover::before { height: 100%; }
  .consequence-card:hover { background: var(--navy-mid); }
  .consequence-vs {
    font-family: 'Raleway', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--silver);
    opacity: 0.5;
    margin-bottom: 20px;
  }
  .consequence-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--silver-light);
    line-height: 1.6;
  }
  .consequence-text strong { font-style: normal; color: var(--pure-white); font-weight: 500; }

  /* ── 13 PONTOS BLOCK ── */
  .pontos-block {
    background: linear-gradient(135deg, var(--navy-light) 0%, var(--navy-mid) 100%);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 120px 60px;
  }
  .pontos-inner { max-width: 1200px; margin: 0 auto; }
  .pontos-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 80px;
    -webkit-align-items: end;
    align-items: end;
  }
  .pontos-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--pure-white);
    line-height: 1.1;
  }
  .pontos-title em { font-style: italic; color: var(--accent-silver); }
  .pontos-title span {
    display: block;
    font-family: 'Raleway', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--silver);
    font-weight: 300;
    font-style: normal;
    margin-bottom: 20px;
    opacity: 0.6;
  }
  .pontos-body { font-size: 0.9rem; line-height: 1.9; color: var(--silver-light); }

  /* ghost numeral */
  .pontos-numero {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(10rem, 22vw, 20rem);
    color: rgba(184,196,208,0.05);
    line-height: 1;
    letter-spacing: -0.05em;
    text-align: center;
    margin: 16px 0 56px;
    -webkit-user-select: none;
    user-select: none;
  }

  /* manifesto cards */
  .pontos-manifesto {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--rule);
  }
  .manifesto-item {
    background: var(--navy-mid);
    padding: 52px 48px;
    position: relative;
    overflow: hidden;
    -webkit-transition: background 0.4s;
    transition: background 0.4s;
    -webkit-tap-highlight-color: transparent;
  }
  .manifesto-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 2px; height: 0;
    background: var(--silver);
    opacity: 0.4;
    -webkit-transition: height 0.5s cubic-bezier(0.22,1,0.36,1);
    transition: height 0.5s cubic-bezier(0.22,1,0.36,1);
  }
  .manifesto-item:hover::before { height: 100%; }
  .manifesto-item:hover { background: var(--navy-light); }
  .manifesto-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    color: rgba(184,196,208,0.08);
    line-height: 1;
    margin-bottom: 24px;
    letter-spacing: -0.04em;
  }
  .manifesto-text { font-size: 0.9rem; color: var(--silver-light); line-height: 1.85; }
  .manifesto-text strong {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--pure-white);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  /* ── FORMATO ── */
  .formato-section {
    background: var(--navy);
    padding: 120px 60px;
  }
  .formato-inner { max-width: 1200px; margin: 0 auto; }
  .formato-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-top: 56px;
    -webkit-align-items: start;
    align-items: start;
  }
  .formato-left {
    border-left: 1px solid var(--rule-strong);
    padding-left: 48px;
  }
  .formato-lead {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3.2vw, 2.8rem);
    font-weight: 300;
    color: var(--pure-white);
    line-height: 1.2;
    margin-bottom: 28px;
  }
  .formato-lead em { font-style: italic; color: var(--accent-silver); }
  .formato-body { font-size: 0.9rem; line-height: 1.9; color: var(--silver-light); }

  .formato-specs {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    gap: 16px;
  }
  .spec-item {
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    gap: 20px;
    padding: 20px 24px;
    background: rgba(13,27,46,0.5);
    border: 1px solid var(--rule);
    -webkit-transition: border-color 0.3s, background 0.3s;
    transition: border-color 0.3s, background 0.3s;
    -webkit-tap-highlight-color: transparent;
  }
  .spec-item:hover {
    border-color: var(--rule-strong);
    background: rgba(13,27,46,0.8);
  }
  .spec-tag {
    font-family: 'Raleway', sans-serif;
    font-size: 0.52rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--silver);
    background: rgba(184,196,208,0.08);
    border: 1px solid var(--rule);
    padding: 5px 10px;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 110px;
    text-align: center;
  }
  .spec-content { font-size: 0.88rem; color: var(--silver-light); line-height: 1.6; }
  .spec-content strong { color: var(--pure-white); font-weight: 400; display: block; margin-bottom: 2px; }

  /* ── INVESTMENT ── */
  .investment-section { padding: 120px 60px; background: var(--navy); }
  .investment-inner { max-width: 1200px; margin: 0 auto; }
  .investment-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 80px;
    -webkit-align-items: end;
    align-items: end;
  }
  .investment-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--pure-white);
    line-height: 1.1;
  }
  .investment-note { font-size: 0.88rem; line-height: 1.8; color: var(--silver); }

  /* pricing board */
  .pricing-board {
    border: 1px solid var(--rule-strong);
    background: var(--navy-mid);
    position: relative;
    overflow: hidden;
  }
  .pricing-board::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--silver), var(--accent-silver), var(--silver), transparent);
    opacity: 0.4;
  }
  .pricing-main {
    padding: 64px 64px 48px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    -webkit-align-items: start;
    align-items: start;
    border-bottom: 1px solid var(--rule);
  }
  .pricing-label {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 0.6rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--silver);
    opacity: 0.65;
    margin-bottom: 20px;
  }
  .pricing-value {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.5rem, 7vw, 6rem);
    color: var(--pure-white);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }
  .pricing-period {
    font-family: 'Raleway', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--silver);
    opacity: 0.5;
  }
  .pricing-installment {
    padding: 28px 36px;
    border: 1px solid var(--rule);
    background: rgba(13,27,46,0.5);
    -webkit-align-self: center;
    align-self: center;
    text-align: center;
    min-width: 200px;
  }
  .inst-label {
    font-family: 'Raleway', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--silver);
    margin-bottom: 12px;
  }
  .inst-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: var(--silver-light);
    font-weight: 300;
    line-height: 1;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }
  .inst-detail {
    font-family: 'Raleway', sans-serif;
    font-size: 0.55rem;
    color: var(--silver);
    opacity: 0.45;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .pricing-footer {
    padding: 32px 64px;
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    gap: 16px;
  }
  .liberacao-badge {
    display: -webkit-inline-flex;
    display: inline-flex;
    -webkit-align-items: center;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--rule-strong);
    padding: 9px 18px;
  }
  .liberacao-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--silver-light);
    -webkit-animation: pulse 2.5s ease-in-out infinite;
    animation: pulse 2.5s ease-in-out infinite;
  }
  .liberacao-badge span {
    font-family: 'Raleway', sans-serif;
    font-size: 0.58rem;
